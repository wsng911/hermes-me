# ============================================================
# Hermes Agent 环境变量配置
# 填好后放到 /home/Hermes-agent/.env
# ============================================================

# ── LLM 提供商（至少填一个）────────────────────────────────

# OpenRouter（推荐，支持200+模型）https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-xxxx

# OpenAI https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-xxxx

# Anthropic https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-xxxx

# Google Gemini https://aistudio.google.com/app/apikey
# GOOGLE_API_KEY=xxxx

# 智谱 GLM（国内）https://open.bigmodel.cn
# GLM_API_KEY=xxxx

# Kimi / Moonshot（国内）https://platform.kimi.ai
# KIMI_API_KEY=sk-kimi-xxxx

# ── 消息平台（按需填写）────────────────────────────────────

# Telegram https://t.me/BotFather
# TELEGRAM_BOT_TOKEN=xxxx
# TELEGRAM_ALLOWED_USERS=123456789  # 你的 Telegram 用户ID

# Discord
# DISCORD_BOT_TOKEN=xxxx

# Slack
# SLACK_BOT_TOKEN=xoxb-xxxx
# SLACK_APP_TOKEN=xapp-xxxx

# ── 工具扩展（可选）────────────────────────────────────────

# 网页搜索 Exa https://exa.ai
# EXA_API_KEY=xxxx

# 图片生成 fal.ai https://fal.ai
# FAL_KEY=xxxx

# 语音（Whisper/TTS）
# VOICE_TOOLS_OPENAI_KEY=sk-xxxx

# ── 调试开关 ────────────────────────────────────────────────
WEB_TOOLS_DEBUG=false
TERMINAL_TIMEOUT=60
